# ─── Backend (Railway service: ecoloop-backend) ─────────────────────────────
# Obtener DB_* desde Railway > Postgres plugin > Connect > Variables
DB_HOST=containers-us-west-xxx.railway.app
DB_PORT=5432
DB_NAME=railway
DB_USER=postgres
DB_PASS=your-postgres-password-from-railway

JWT_SECRET=genera-con: openssl rand -hex 32

GEMINI_API_KEY=AIza...
# Obtener en: https://aistudio.google.com/apikey

FRONTEND_URL=https://ecoloop-frontend.up.railway.app
# URL del servicio frontend en Railway (para CORS)
# Si el frontend esta en Vercel, usar la URL de Vercel

# PORT es seteado automaticamente por Railway, no agregar

# ─── Frontend (Railway service: ecoloop-frontend) ────────────────────────────
VITE_API_URL=https://ecoloop-backend.up.railway.app
# URL del servicio backend en Railway
# IMPORTANTE: se pasa como build arg en el Dockerfile (ARG VITE_API_URL)

# ─── Local dev ───────────────────────────────────────────────────────────────
# Para desarrollo local usar:
# SERVER_PORT=8082
# DB_HOST=localhost
# DB_PORT=5434   (docker-compose expone en 5434 para no pisar postgres local)
# DB_NAME=ecoloop_db
# DB_USER=ecoloop_user
# DB_PASS=ecoloop_pass
# JWT_SECRET=local-secret-minimo-32-caracteres-ok
# GEMINI_API_KEY=tu-key
# FRONTEND_URL=http://localhost:5173
# (VITE_API_URL no se setea en dev, el proxy de Vite lo maneja)
